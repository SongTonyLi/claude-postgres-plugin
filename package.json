{
  "name": "claude-sqlite-plugin",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "csp": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts start",
    "web": "bun run src/index.ts web",
    "import": "bun run src/index.ts import",
    "mcp": "bun run src/mcp-server.ts",
    "build:web": "cd web && bun --bun vite build",
    "build:bin": "bun build --compile src/index.ts --outfile bin/csp",
    "build": "bun run build:web && bun run build:bin",
    "test": "CSP_DB_PATH=:memory: bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "eventemitter3": "^5.0.4",
    "hono": "^4.12.16"
  }
}
